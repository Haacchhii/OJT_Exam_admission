# ──────────────────────────────────────────────
# Golden Key — Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Environment ─────────────────────────────
# Set to "production" when deploying
NODE_ENV="development"

# ─── Database (Supabase PostgreSQL) ──────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Transaction mode (port 6543) — used by Prisma for queries
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── JWT ──────────────────────────────────────
# MUST be a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="60m"
# Set to "true" to require applicants to verify email before using protected routes.
# Set to "false" for seeded/demo accounts that do not complete verification flow.
EMAIL_VERIFICATION_REQUIRED="true"

# ─── Server ──────────────────────────────────
PORT=3000
# Align server date handling with Philippines time.
TZ="Asia/Manila"
# Set to your deployed URL in production
CORS_ORIGIN="http://localhost:5173,https://ojt-exam-admission.vercel.app"

# ─── File upload ──────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# ─── Email (SMTP) ─────────────────────────────
# Option A — Gmail (use a Google App Password, not your regular password)
# SMTP_USER="youremail@gmail.com"
# SMTP_PASS="your-google-app-password"
#
# Option B — Custom SMTP (Outlook, SendGrid, Mailtrap, etc.)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@yourdomain.com"
# SMTP_PASS="your-smtp-password"
#
# The display name / From address for outgoing emails
# SMTP_FROM="Golden Key School <noreply@yourdomain.com>"
#
# Optional: For testing in dev, leave all SMTP vars empty and emails will print to console.

# ─── App URL (for email links) ────────────────
# Set to your deployed frontend URL in production
APP_URL="https://ojt-exam-admission.vercel.app"

# ─── Safe Scalability Rollout ───────────────
# Optional distributed cache. Keep disabled until Redis is ready.
ENABLE_REDIS_CACHE="false"
# Example: redis://default:password@host:6379
REDIS_URL=""
# Short timeout prevents request stalls if Redis has issues.
REDIS_CONNECT_TIMEOUT_MS=1500

# Prevents applicant status sync from running on every request.
# 0 = disable throttling (sync check every request).
APPLICANT_STATUS_SYNC_TTL_MS=60000

# DB connection pool tuning for serverless concurrency.
# Keep these unset to use built-in defaults.
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=10

# Toggle role-aware dashboard query trimming.
# Set to "false" to force legacy full-query behavior as a quick rollback.
DASHBOARD_ROLE_AWARE_QUERIES="true"
