# ──────────────────────────────────────────────
# Golden Key — Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Environment ─────────────────────────────
# Set to "production" when deploying
NODE_ENV="development"

# ─── Database (Supabase PostgreSQL) ──────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Transaction mode (port 6543) — used by Prisma for queries
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── JWT ──────────────────────────────────────
# MUST be a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="60m"
# Set to "true" to require applicants to verify email before using protected routes.
# Set to "false" for seeded/demo accounts that do not complete verification flow.
EMAIL_VERIFICATION_REQUIRED="true"

# ─── Server ──────────────────────────────────
PORT=3000
# Set to your deployed URL in production (e.g. https://goldenkey.example.com)
CORS_ORIGIN="http://localhost:5173,https://your-frontend-domain.com"

# ─── File upload ──────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# ─── Email (SMTP) ─────────────────────────────
# Option A — Gmail (use a Google App Password, not your regular password)
# SMTP_USER="youremail@gmail.com"
# SMTP_PASS="your-google-app-password"
#
# Option B — Custom SMTP (Outlook, SendGrid, Mailtrap, etc.)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@yourdomain.com"
# SMTP_PASS="your-smtp-password"
#
# The display name / From address for outgoing emails
# SMTP_FROM="Golden Key School <noreply@yourdomain.com>"
#
# Optional: For testing in dev, leave all SMTP vars empty and emails will print to console.

# ─── App URL (for email links) ────────────────
# Set to your deployed frontend URL in production
APP_URL="https://your-frontend-domain.com"
