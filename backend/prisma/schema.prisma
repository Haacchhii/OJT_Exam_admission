generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ────────────────────────────────────────────
model User {
  id            Int      @id @default(autoincrement())
  firstName     String   @map("first_name")
  middleName    String?  @map("middle_name")
  lastName      String   @map("last_name")
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   @default("applicant") // administrator | registrar | teacher | applicant
  status        String   @default("Active")    // Active | Inactive
  phone         String?
  address       String?
  emailVerified Boolean  @default(false) @map("email_verified")
  emailVerifyToken  String?  @map("email_verify_token")
  emailVerifyExpires DateTime? @map("email_verify_expires")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  admissions      Admission[]
  examsCreated    Exam[]             @relation("ExamCreator")
  reviewedResults ExamResult[]       @relation("ResultReviewer")
  scoredEssays    EssayAnswer[]      @relation("EssayScorer")
  reviewedDocs    AdmissionDocument[] @relation("DocumentReviewer")
  reviewedDocSubmissions AdmissionDocumentSubmission[] @relation("DocumentSubmissionReviewer")
  auditLogs       AuditLog[]
  examRegistrations ExamRegistration[] @relation("ExamRegistrationUser")

  applicantProfile  ApplicantProfile?
  staffProfile      StaffProfile?

  @@index([deletedAt, createdAt])
  @@index([deletedAt, role, createdAt])
  @@index([deletedAt, status, createdAt])
  @@index([deletedAt, role])
  @@map("users")
}

// ─── Admissions ───────────────────────────────────────
model Admission {
  id              Int      @id @default(autoincrement())
  trackingId      String   @unique @map("tracking_id") // e.g. GK-ADM-2026-00001
  userId          Int      @map("user_id")
  firstName       String   @map("first_name")
  middleName      String?  @map("middle_name")
  lastName        String   @map("last_name")
  email           String
  phone           String?
  dob             String   // stored as ISO date string
  gender          String   // Male | Female
  address         String
  gradeLevel      String   @map("grade_level")
  levelGroup      String?  @map("level_group")
  prevSchool      String?  @map("prev_school")
  schoolYear      String   @map("school_year")
  lrn             String?
  applicantType   String   @default("New") @map("applicant_type") // New | Transferee | Returning | Continuing
  studentNumber   String?  @map("student_number") // pre-filled for continuing students, assigned for new on acceptance
  guardian        String
  guardianRelation String  @map("guardian_relation")
  guardianPhone   String?  @map("guardian_phone")
  guardianEmail   String?  @map("guardian_email")
  status          String   @default("Submitted") // Submitted | Under Screening | Under Evaluation | Accepted | Rejected
  notes           String?
  academicYearId  Int?     @map("academic_year_id")
  semesterId      Int?     @map("semester_id")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents     AdmissionDocument[]
  documentSubmissions AdmissionDocumentSubmission[]
  academicYear  AcademicYear?       @relation(fields: [academicYearId], references: [id])
  semester      Semester?           @relation(fields: [semesterId], references: [id])
  @@index([userId])
  @@index([status])
  @@index([gradeLevel])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([submittedAt])
  @@index([deletedAt])
  @@index([deletedAt, status, submittedAt])
  @@index([deletedAt, status, academicYearId])
  @@index([deletedAt, levelGroup, gradeLevel, submittedAt])
  @@index([deletedAt, academicYearId, semesterId, submittedAt])
  @@map("admissions")
}

model AdmissionDocument {
  id            Int       @id @default(autoincrement())
  admissionId   Int       @map("admission_id")
  documentName  String    @map("document_name")
  filePath      String?   @map("file_path")
  uploadedAt    DateTime  @default(now()) @map("uploaded_at")
  extractedText String?   @map("extracted_text")
  extractedData String?   @map("extracted_data") // JSON string of parsed key-value fields
  extractedAt   DateTime? @map("extracted_at")
  reviewStatus  String    @default("pending") @map("review_status") // pending | accepted | rejected
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedById  Int?      @map("reviewed_by_id")
  reviewNote    String?   @map("review_note")

  admission  Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  submissions AdmissionDocumentSubmission[]

  @@index([admissionId])
  @@map("admission_documents")
}

model AdmissionDocumentSubmission {
  id                 Int      @id @default(autoincrement())
  admissionId        Int      @map("admission_id")
  admissionDocumentId Int?    @map("admission_document_id")
  originalFileName   String   @map("original_file_name")
  storedFilePath     String   @map("stored_file_path")
  mimeType           String?  @map("mime_type")
  fileSize           Int?     @map("file_size")
  uploadedAt         DateTime @default(now()) @map("uploaded_at")
  extractedText      String?  @map("extracted_text")
  extractedData      String?  @map("extracted_data")
  extractedAt        DateTime? @map("extracted_at")
  reviewStatus       String   @default("pending") @map("review_status")
  reviewedAt         DateTime? @map("reviewed_at")
  reviewedById       Int?     @map("reviewed_by_id")
  reviewNote         String?  @map("review_note")

  admission         Admission         @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  admissionDocument AdmissionDocument? @relation(fields: [admissionDocumentId], references: [id], onDelete: SetNull)
  reviewedBy        User?             @relation("DocumentSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([admissionId])
  @@index([admissionDocumentId])
  @@index([uploadedAt])
  @@map("admission_document_submissions")
}

// ─── Exams ────────────────────────────────────────────
model Exam {
  id              Int      @id @default(autoincrement())
  title           String
  gradeLevel      String   @map("grade_level")
  levelGroup      String?  @map("level_group")
  durationMinutes Int      @map("duration_minutes")
  passingScore    Float    @map("passing_score") // percentage 0-100
  isActive        Boolean  @default(true) @map("is_active")
  academicYearId  Int?     @map("academic_year_id")
  semesterId      Int?     @map("semester_id")
  createdById     Int?     @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  createdBy    User?          @relation("ExamCreator", fields: [createdById], references: [id], onDelete: SetNull)
  questions    ExamQuestion[]
  schedules    ExamSchedule[]
  academicYear AcademicYear?  @relation(fields: [academicYearId], references: [id])
  semester     Semester?      @relation(fields: [semesterId], references: [id])

  @@index([gradeLevel])
  @@index([isActive])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("exams")
}

model ExamQuestion {
  id           Int    @id @default(autoincrement())
  examId       Int    @map("exam_id")
  questionText String @map("question_text")
  questionType String @map("question_type") // mc | essay | identification | true_false
  identificationAnswer String? @map("identification_answer")
  identificationMatchMode String? @map("identification_match_mode") // exact | partial
  points       Int
  orderNum     Int    @map("order_num")

  exam             Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  choices          QuestionChoice[]
  submittedAnswers SubmittedAnswer[]
  essayAnswers     EssayAnswer[]

  @@unique([examId, orderNum])
  @@map("exam_questions")
}

model QuestionChoice {
  id         Int     @id @default(autoincrement())
  questionId Int     @map("question_id")
  choiceText String  @map("choice_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  orderNum   Int     @map("order_num")

  question   ExamQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn SubmittedAnswer[]

  @@index([questionId])
  @@map("question_choices")
}

// ─── Schedules & Registrations ────────────────────────
model ExamSchedule {
  id            Int      @id @default(autoincrement())
  examId        Int      @map("exam_id")
  scheduledDate String   @map("scheduled_date") // YYYY-MM-DD
  startTime     String   @map("start_time")     // HH:mm
  endTime       String   @map("end_time")       // HH:mm
  visibilityStartDate String?  @map("visibility_start_date")  // YYYY-MM-DD (when exam becomes visible to students)
  visibilityEndDate   String?  @map("visibility_end_date")    // YYYY-MM-DD (when exam stops being visible, typically 10 days from start)
  registrationOpenDate  String?  @map("registration_open_date")  // YYYY-MM-DD
  registrationCloseDate String?  @map("registration_close_date") // YYYY-MM-DD
  examWindowStartAt DateTime? @map("exam_window_start_at")
  examWindowEndAt   DateTime? @map("exam_window_end_at")
  maxSlots      Int      @map("max_slots")
  slotsTaken    Int      @default(0) @map("slots_taken")
  venue         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  exam          Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  registrations ExamRegistration[]

  @@index([examId])
  @@index([scheduledDate])
  @@index([examId, scheduledDate])
  @@index([scheduledDate, examId])
  @@map("exam_schedules")
}

model ExamRegistration {
  id          Int       @id @default(autoincrement())
  trackingId  String    @unique @map("tracking_id") // e.g. GK-EXM-2026-00001
  userEmail   String    @map("user_email")
  userId      Int?      @map("user_id")
  scheduleId  Int       @map("schedule_id")
  status      String    @default("scheduled") // scheduled | started | done
  startedAt   DateTime? @map("started_at")
  submittedAt DateTime? @map("submitted_at")
  draftAnswers String?  @map("draft_answers") // JSON draft for auto-save during exam
  createdAt   DateTime  @default(now()) @map("created_at")

  schedule         ExamSchedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user             User?             @relation("ExamRegistrationUser", fields: [userId], references: [id], onDelete: Cascade)
  result           ExamResult?
  submittedAnswers SubmittedAnswer[]
  essayAnswers     EssayAnswer[]

  @@index([userEmail])
  @@index([userId])
  @@index([scheduleId])
  @@index([status])
  @@index([userEmail, status])
  @@index([scheduleId, status])
  @@index([userEmail, status, scheduleId])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([userEmail, createdAt])
  @@index([createdAt])
  @@map("exam_registrations")
}

// ─── Results ──────────────────────────────────────────
model ExamResult {
  id             Int      @id @default(autoincrement())
  registrationId Int      @unique @map("registration_id")
  totalScore     Int      @default(0) @map("total_score")
  maxPossible    Int      @map("max_possible")
  percentage     Float
  passed         Boolean  @default(false)
  essayReviewed  Boolean  @default(false) @map("essay_reviewed")
  reviewedById   Int?     @map("reviewed_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  registration ExamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  reviewedBy   User?            @relation("ResultReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([passed])
  @@index([passed, createdAt])
  @@map("exam_results")
}

model SubmittedAnswer {
  id               Int      @id @default(autoincrement())
  registrationId   Int      @map("registration_id")
  questionId       Int      @map("question_id")
  selectedChoiceId Int?     @map("selected_choice_id")
  essayText        String?  @map("essay_text")
  createdAt        DateTime @default(now()) @map("created_at")

  registration   ExamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  question       ExamQuestion     @relation(fields: [questionId], references: [id])
  selectedChoice QuestionChoice?  @relation(fields: [selectedChoiceId], references: [id])

  @@unique([registrationId, questionId])
  @@index([registrationId])
  @@index([questionId])
  @@map("submitted_answers")
}

model EssayAnswer {
  id             Int       @id @default(autoincrement())
  registrationId Int       @map("registration_id")
  questionId     Int       @map("question_id")
  essayResponse  String    @map("essay_response")
  pointsAwarded  Int?      @map("points_awarded")
  maxPoints      Int       @map("max_points")
  comment        String?   // teacher feedback on essay
  scored         Boolean   @default(false)
  scoredById     Int?      @map("scored_by")
  scoredAt       DateTime? @map("scored_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  registration ExamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  question     ExamQuestion     @relation(fields: [questionId], references: [id])
  scoredBy     User?            @relation("EssayScorer", fields: [scoredById], references: [id], onDelete: SetNull)

  @@index([scored])
  @@index([registrationId])
  @@index([registrationId, scored])
  @@index([scored, createdAt])
  @@unique([registrationId, questionId])
  @@map("essay_answers")
}

// ─── Audit Trail ──────────────────────────────────────
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String   // e.g. "admission.status_update", "user.create", "exam.delete"
  entity    String   // e.g. "admission", "user", "exam", "result"
  entityId  Int?     @map("entity_id")
  details   String?  // JSON string with extra context
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entity, createdAt])
  @@index([action, createdAt])
  @@index([action, entity, createdAt])
  @@map("audit_logs")
}

// ─── Academic Year ──────────────────────────────────
model AcademicYear {
  id        Int        @id @default(autoincrement())
  year      String     @unique                    // e.g. "2026-2027"
  isActive  Boolean    @default(false) @map("is_active")
  startDate DateTime?  @map("start_date")
  endDate   DateTime?  @map("end_date")
  createdAt DateTime   @default(now()) @map("created_at")

  semesters   Semester[]
  admissions  Admission[]
  exams       Exam[]

  @@map("academic_years")
}

// ─── Semester / Period ──────────────────────────────
model Semester {
  id             Int          @id @default(autoincrement())
  name           String       // "First Semester" | "Second Semester" | "Summer"
  academicYearId Int          @map("academic_year_id")
  isActive       Boolean      @default(false) @map("is_active")
  startDate      DateTime?    @map("start_date")
  endDate        DateTime?    @map("end_date")
  createdAt      DateTime     @default(now()) @map("created_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  admissions   Admission[]
  exams        Exam[]

  @@unique([academicYearId, name])
  @@map("semesters")
}

// ─── Role Profiles ───────────────────────────────────
model ApplicantProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique @map("user_id")
  studentNumber String?  @unique @map("student_number") // e.g. GKISSJ-2026-00001 (assigned on acceptance)
  lrn           String?
  gradeLevel    String?  @map("grade_level")
  levelGroup    String?  @map("level_group")
  guardian      String?
  guardianPhone String?  @map("guardian_phone")
  guardianEmail String?  @map("guardian_email")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("applicant_profiles")
}

model StaffProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  employeeId String?  @unique @map("employee_id")
  department String?
  position   String?
  hireDate   DateTime? @map("hire_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}


