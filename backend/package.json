{
  "name": "golden-key-backend",
  "version": "1.0.0",
  "description": "Golden Key Integrated School — Admission & Examination System API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:backup": "node prisma/backup-data.js",
    "db:restore": "node prisma/restore-backup.js",
    "db:audit-accounts": "node prisma/audit-accounts.js",
    "db:test-role-aspects": "node prisma/test-role-aspects.js",
    "db:reset": "node prisma/safe-reset.js",
    "db:studio": "npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf:smoke": "node scripts/perf-smoke.mjs"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^19.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "vitest": "^4.0.18"
  }
