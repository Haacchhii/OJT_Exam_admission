# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/golden
# Optional direct URL for connection pooling
DIRECT_URL=

# Redis cache (enable and set URL to use Redis/Upstash)
ENABLE_REDIS_CACHE=1
REDIS_URL=redis://:password@localhost:6379
REDIS_CONNECT_TIMEOUT_MS=5000

# Summary endpoint / materialized view
USE_MATERIALIZED_SUMMARY=1
SUMMARY_CACHE_MS=300000
SUMMARY_REFRESH_INTERVAL_MS=300000

# Misc
NODE_ENV=development
PORT=3000
