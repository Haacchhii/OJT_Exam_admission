# ──────────────────────────────────────────────
# Golden Key — Frontend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in values.
# Any variable prefixed with VITE_ is exposed to the browser.

# Backend API URL (required) — points to the Express API server
# Example: /api  (when using Vite proxy)  or  http://localhost:3000/api
VITE_API_URL=/api

# Maximum file upload size in MB (default: 10)
VITE_MAX_UPLOAD_MB=10
